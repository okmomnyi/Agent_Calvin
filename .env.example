# AgentOS environment — copy to .env and fill in. .env is gitignored, never commit it.

# --- LLM (NVIDIA NIM, free credits at build.nvidia.com) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # required: default NIM bearer token

# OPTIONAL per-task keys — set these to spread concurrent load across separate rate-limit
# buckets (the scheduler, Telegram bot, and voice can each hit a different key at once).
# Each maps to a task class in config.yaml's llm.routes. ANY that is left blank falls back
# to NVIDIA_API_KEY, so you can start with just the one key above and add these later.
# classify + voice_chat (cheap, high-volume)
NVIDIA_API_KEY_FAST=
# write + persona (drafting: covers, notes, answers)
NVIDIA_API_KEY_WRITE=
# code_review (code tutor / diff review)
NVIDIA_API_KEY_CODE=
# research (web synthesis, interview prep, deep reasoning)
NVIDIA_API_KEY_RESEARCH=

# --- Database (PostgreSQL — raw SQL, no ORM) ---
DATABASE_URL=postgresql://agentos:agentos@localhost:5432/agentos
# used only by the test suite (each test gets its own schema in this DB)
TEST_DATABASE_URL=postgresql://agentos:agentos@localhost:5432/agentos_test

# --- Identity ---
MY_NAME=Calvin
MY_EMAIL=you@example.com

# --- Telegram (Phase 8) ---
# from @BotFather
TELEGRAM_BOT_TOKEN=
# the single authorized chat id
TELEGRAM_CHAT_ID=

# --- WhatsApp/SMS via Africa's Talking (Phase 16 flip notifications) ---
# Africa's Talking username ('sandbox' for testing)
AT_USERNAME=
# Africa's Talking API key
AT_API_KEY=
# Calvin's number in E.164, e.g. +2547XXXXXXXX
AT_PHONE=
# WhatsApp needs an approved sender and its endpoint is account-specific — set BOTH to
# enable it. Leave blank and flip alerts fall back to SMS on the same account.
AT_WHATSAPP_FROM=
AT_WHATSAPP_ENDPOINT=

# --- Spotify (Phase 22) — requires a PREMIUM account (Spotify restricts new apps) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Obtained once via `python manage.py music connect` — kept here, never in the database.
SPOTIFY_REFRESH_TOKEN=

# --- Remote API + Voice WebSocket auth (Phase 7) ---
AGENT_WS_TOKEN=change-me-to-a-long-random-string   # shared secret for /api/command + /ws/voice
# Local default; replace with wss://your-domain/ws/voice when the kernel is on a VPS.
AGENT_WS_URL=ws://127.0.0.1:8000/ws/voice
# Voice endpoint tuning: tolerate natural pauses and longer spoken job descriptions.
AGENT_END_SILENCE_MS=1800
AGENT_MAX_UTTERANCE_SECONDS=45
AGENT_WHISPER_MODEL=base
# Lower the floor if a quiet microphone misses attempts to talk over a reply.
AGENT_BARGE_MIN_RMS=700
AGENT_BARGE_ECHO_RATIO=1.5

# --- Behaviour flags ---
# (none. AUTO_APPLY was removed: it let a hunt send applications in Calvin's name with no
# per-job approval, which is the same gap Phase 30 closes by keeping `high` out of
# LEARNABLE_TIERS. Applications are sent by `approve <ids>` and nothing else. §0 P3.)

# --- Optional ---
# SERPAPI_KEY=                      # Phase 3: Google Jobs via SerpAPI (optional, free tier)

# Phase 25 (GitHub persona import). Both optional.
# GITHUB_USER overrides config.yaml `github.user` — whose repos to read.
# GITHUB_TOKEN is a plain read-only PAT; it only raises GitHub's rate ceiling from 60 to
# 5000 requests/hour. A full import of ~45 repos fits inside 60/hr, so this matters when
# re-running the import repeatedly, not for a first run.
# GITHUB_USER=
# GITHUB_TOKEN=

# Gmail token location. Set by docker-compose to /app/secrets/token.json — the secrets/
# mount is a DIRECTORY on purpose: bind-mounting a token.json that doesn't exist yet makes
# Docker create a directory in its place, turning "run manage.py auth first" into
# IsADirectoryError. Must be writable; the token is rewritten on every hourly refresh.
# GOOGLE_TOKEN_PATH=

# Laptop voice client only (see client/README.md). Defaults in brackets.
# AGENT_WAKE_WORD=                  # wake word model name [hey_jarvis]
# AGENT_WAKE_THRESHOLD=             # 0-1 detection confidence [0.5]
# AGENT_WAKE_FRAMEWORK=             # openwakeword backend [onnx] — tflite has no Windows wheel
# AGENT_PTT_KEY=                    # push-to-talk key for --ptt mode [ctrl+space]
# AGENT_CLIENT_MODE=                # read by client/autostart/agentos-laptop.ps1 [window].
#                                   # `voice` restores the always-on wake word — opt-in only,
#                                   # because nobody opts OUT of a hot microphone.

# Worker tuning (Phase 26).
# AGENT_WORKER_IDLE_SLEEP=          # seconds between claim attempts when the queue is empty [2.0]

# --- Server ---
AGENTOS_HOST=0.0.0.0
AGENTOS_PORT=8000
AGENTOS_TZ=Africa/Nairobi
